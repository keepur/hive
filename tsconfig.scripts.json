{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist/scripts",
    "rootDir": "scripts",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "scripts/agent-id-rename-map.ts",
    "scripts/migrate-agent-ids.ts"
  ],
  "exclude": ["node_modules", "scripts/**/*.test.ts"]
}
