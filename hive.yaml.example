# Hive Instance Configuration
# Generated by: npm run setup
# Edit this file to change your business info, SMS lines, etc.
# Restart Hive after making changes.

business:
  name: "Your Business Name"
  description: "what your business does, in one sentence"
  location: "City, State"
  owner:
    name: "Your Name"
    role: "CEO"

# SMS lines (requires Quo/OpenPhone integration)
# sms:
#   lines:
#     - id: "PNxxxxx"           # Phone Number ID from Quo
#       label: "Main Line"       # Display name
#       number: "(555) 123-4567" # Phone number
#       slackChannel: "sms-main" # Slack channel for incoming SMS

# Named Quo lines for the quo_send_sms tool
# quo:
#   lines:
#     main:
#       id: "PNxxxxx"
#       number: "(555) 123-4567"
#       label: "Main Line"
#     personal:
#       id: "PNyyyyy"
#       number: "(555) 987-6543"
#       label: "Personal"
