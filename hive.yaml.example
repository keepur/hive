# Hive Instance Configuration
# Generated by: npm run setup
# Edit this file to change your business info, SMS lines, etc.
# Restart Hive after making changes.

business:
  name: "Your Business Name"
  description: "what your business does, in one sentence"
  location: "City, State"
  owner:
    name: "Your Name"
    role: "CEO"

# SMS lines (requires Quo/OpenPhone integration)
# sms:
#   lines:
#     - id: "PNxxxxx"           # Phone Number ID from Quo
#       label: "Main Line"       # Display name
#       number: "(555) 123-4567" # Phone number
#       slackChannel: "sms-main" # Slack channel for incoming SMS

# Named Quo lines for the quo_send_sms tool
# quo:
#   lines:
#     main:
#       id: "PNxxxxx"
#       number: "(555) 123-4567"
#       label: "Main Line"
#     personal:
#       id: "PNyyyyy"
#       number: "(555) 987-6543"
#       label: "Personal"

# Plugins — enable business-specific integrations
# plugins:
#   - dodi  # DodiHome manufacturing integrations

# Slack audit channel — receives app/SMS notifications
# slack:
#   auditChannel: jessica
#   localMcpServer: true    # default: local bot-token Slack MCP (self-echo-safe). Set false to fall back to the hosted cloud MCP (user-OAuth identity — not recommended; see KPR-97).

# slackInternal:
#   # port auto-derived from instance portBase if omitted
#   # port: 3106

# Google Workspace
# googleWorkspace:
#   account: bot@yourdomain.com
#   sharedFolder: your-shared-folder-id

# Email (Resend)
# resend:
#   emailDomain: yourdomain.com
#   businessName: Your Business

# Retention policy — age-based sweep of agent scratch/feeds/playwright and pipeline data dirs.
# Ships in dry-run mode by default: the sweeper reports what it would delete to the
# Slack audit channel, but does not delete until `enabled: true`.
# retention:
#   enabled: false
#   intervalMs: 604800000   # 7 days
#   defaults:
#     days: 7
#   paths:
#     data: 7
#     "agents/*/scratch": 7
#     "agents/*/feeds": 7
#     "agents/*/playwright": 3
#     "agents/*/reports": 0   # 0 = keep forever
#     logs: 30
