# Slack
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_MCP_TOKEN=xoxp-...  # User token for Slack MCP server (OAuth)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Linear
LINEAR_API_KEY=lin_api_...

# GitHub (for hive-memory repo)
HIVE_MEMORY_REPO=your-org/hive-memory
HIVE_MEMORY_LOCAL_PATH=~/hive-memory

# Brave Search
BRAVE_API_KEY=BSA...

# Agent defaults
DEFAULT_AGENT=chief-of-staff
DEFAULT_MODEL=claude-sonnet-4-6

# Scheduler
HEARTBEAT_INTERVAL_MS=120000

# Recall.ai (meeting transcription)
RECALL_API_KEY=
RECALL_API_REGION=us-west-2
MEETING_MONITOR_PORT=3101
MEETING_MONITOR_PUBLIC_URL=  # Public URL for real-time transcript webhooks (e.g. ngrok/cloudflare tunnel)
