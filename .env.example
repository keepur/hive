# Slack
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_MCP_TOKEN=xoxp-...  # User token for Slack MCP server (OAuth)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Linear
LINEAR_API_KEY=lin_api_...

# GitHub (for hive-memory repo)
HIVE_MEMORY_REPO=your-org/hive-memory
HIVE_MEMORY_LOCAL_PATH=~/hive-memory

# Brave Search
BRAVE_API_KEY=BSA...

# Agent defaults
