# Slack
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_MCP_TOKEN=xoxp-...  # User token for Slack MCP server (OAuth)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Linear
LINEAR_API_KEY=lin_api_...

# GitHub (for hive-memory repo)
HIVE_MEMORY_REPO=your-org/hive-memory
HIVE_MEMORY_LOCAL_PATH=~/hive-memory

# Brave Search
BRAVE_API_KEY=BSA...

# Agent defaults
DEFAULT_AGENT=chief-of-staff
DEFAULT_MODEL=claude-sonnet-4-6

# Scheduler
HEARTBEAT_INTERVAL_MS=120000

# Task Ledger (dodi_v2 REST API)
TASK_LEDGER_API_URL=http://localhost:3002
# Per-agent keys — env var suffix maps to agent ID (underscores become hyphens)
TASK_LEDGER_KEY_CHIEF_OF_STAFF=dod_...
TASK_LEDGER_KEY_JASPER=dod_...
TASK_LEDGER_KEY_RIVER=dod_...
TASK_LEDGER_KEY_RAE=dod_...
TASK_LEDGER_KEY_COLT=dod_...
TASK_LEDGER_KEY_CHLOE=dod_...
# Fallback shared key (used if no per-agent key matches)
TASK_LEDGER_API_KEY=

# Recall.ai (meeting transcription)
RECALL_API_KEY=
RECALL_API_REGION=us-west-2
MEETING_MONITOR_PORT=3101
MEETING_MONITOR_PUBLIC_URL=  # Public URL for real-time transcript webhooks (e.g. ngrok/cloudflare tunnel)
