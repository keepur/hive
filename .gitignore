node_modules/
dist/
.env
.npmrc
*.tsbuildinfo
.DS_Store

# Customer-space skills (runtime-only, not shipped with engine)
/skills/

# Instance-specific (generated by setup wizard)
hive.yaml
beekeeper.yaml
# Instance-installed plugins (registry-fetched). The bundled `plugins/dodi/`
# tree is engine-owned and stays tracked. Negation inside an ignored parent
# is a git no-op, so we enumerate the instance-local subdirs individually.
/plugins/claude-code/
logs/
.hive-generated.json
.hive/

# Instance sibling namespaces (KPR-51 / Phase 1 of KPR-50)
/agents/
/workflow/
/data/

# Generated plists (machine-specific paths)
service/com.hive.*.plist
coverage/
.qdrant-initialized
pkg/

# Spike test scratch files (recreated each test run)
src/archetypes/fixtures/spike-b/DENIED_target.txt

# Personal / machine-local state — not shared across the team. These
# files were being picked up by `git add -A` and nearly landed in a
# commit by mistake; keep the pattern list tight so `git status` stays
# readable but new personal files in the same categories don't leak.
.env-personal
hive-personal.yaml
agents-personal/
mokie-*.png
.playwright-mcp/
test-results/
.mcp.json
