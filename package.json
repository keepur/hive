{
  "name": "@keepur/hive",
  "version": "0.4.0",
  "hiveApi": "1.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keepur/hive.git"
  },
  "homepage": "https://github.com/keepur/hive#readme",
  "bugs": {
    "url": "https://github.com/keepur/hive/issues",
    "email": "beta@keepur.io"
  },
  "bin": {
    "hive": "pkg/cli.min.js",
    "honeypot": "scripts/honeypot"
  },
  "files": [
    "pkg/",
    "seeds/",
    "templates/",
    "scripts/honeypot",
    "install/",
    "service/"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "postversion": "git push --follow-tags",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "setup": "npx tsx src/cli.ts init",
    "setup:instance": "npx tsx setup/setup-instance.ts",
    "setup:constitution": "npx tsx setup/setup-constitution.ts",
    "setup:seeds": "npx tsx setup/setup-seeds.ts",
    "setup:plugins": "npx tsx setup/sync-plugins.ts",
    "migrate:agents:legacy": "npx tsx setup/migrate-agents.ts",
    "migrate:split-crm-contacts": "npx tsx setup/migrate-split-crm-contacts.ts",
    "migrate:contacts-categories": "npx tsx scripts/migrate-contacts-categories.ts",
    "setup:plist": "npx tsx setup/generate-plist.ts",
    "update": "git pull && npm install && npm run build",
    "reindex": "npx tsx scripts/code-index.ts",
    "lint": "eslint src/ setup/",
    "lint:fix": "eslint --fix src/ setup/",
    "format": "prettier --write \"src/**/*.ts\" \"setup/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"setup/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "check:bundle": "npm run bundle && node scripts/check-bundle-strings.mjs && node scripts/check-bundle-pack.mjs && node scripts/check-bundle-runtime.mjs",
    "bundle": "npm run build && npx tsx build/bundle.ts",
    "prepublishOnly": "npm run bundle"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@anthropic-ai/sdk": "^0.82.0",
    "@linear/sdk": "^76.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@qdrant/js-client-rest": "^1.17.0",
    "@slack/socket-mode": "^2.0.5",
    "@slack/web-api": "^7.14.1",
    "better-sqlite3": "^12.8.0",
    "brave-search-mcp": "^2.0.1",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "mammoth": "^1.11.0",
    "mongodb": "^7.1.0",
    "pdf-parse": "^2.4.5",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
