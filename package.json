{
  "name": "hive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.plugins.json",
    "build:plugins": "tsc -p tsconfig.plugins.json",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "setup": "npx tsx setup/setup-wizard.ts",
    "setup:prereqs": "bash setup/install-prereqs.sh",
    "setup:agents": "npx tsx setup/generate-agents.ts",
    "setup:plist": "npx tsx setup/generate-plist.ts",
    "update": "git pull && npm install && npm run build",
    "embed:hubspot": "npx tsx scripts/hubspot-embed.ts",
    "embed:dodi": "npx tsx scripts/dodi-embed.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@linear/sdk": "^76.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@qdrant/js-client-rest": "^1.17.0",
    "@slack/socket-mode": "^2.0.5",
    "@slack/web-api": "^7.14.1",
    "brave-search-mcp": "^2.0.1",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "mongodb": "^7.1.0",
    "pdf-parse": "^2.4.5",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
